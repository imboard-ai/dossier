{
  "name": "@ai-dossier/mcp-server",
  "version": "1.0.5",
  "description": "MCP server for dossier automation standard - enables LLMs to discover, verify, and execute dossiers",
  "main": "dist/index.js",
  "bin": {
    "dossier-mcp-server": "dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "dossier",
    "automation",
    "llm",
    "ai",
    "model-context-protocol"
  ],
  "author": "Yuval Dimnik <yuval.dimnik@gmail.com>",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/imboard-ai/ai-dossier.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/imboard-ai/ai-dossier#readme",
  "bugs": {
    "url": "https://github.com/imboard-ai/ai-dossier/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "commonjs",
  "mcpName": "ai.imboard/dossier",
  "files": [
    "dist/",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@ai-dossier/core": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
