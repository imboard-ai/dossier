{
  "name": "@ai-dossier/cli",
  "version": "0.8.0",
  "description": "Command-line tool for creating, verifying, and executing dossiers",
  "main": "dist/cli.js",
  "bin": {
    "ai-dossier": "./bin/ai-dossier"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node test/smoke/login.smoke.mjs ./bin/ai-dossier"
  },
  "keywords": [
    "dossier",
    "security",
    "verification",
    "checksum",
    "signature",
    "automation",
    "cli"
  ],
  "author": "Imboard AI",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/imboard-ai/ai-dossier.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/imboard-ai/ai-dossier#readme",
  "bugs": {
    "url": "https://github.com/imboard-ai/ai-dossier/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@ai-dossier/core": "^1.2.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.10.0",
    "vitest": "^4.0.9",
    "@vitest/coverage-v8": "^4.0.9"
  }
}
